# ─── Eventbrite ───────────────────────────────────────────────
# Get from: https://www.eventbrite.com/platform/api
EVENTBRITE_TOKEN=your_eventbrite_private_token_here

# ─── Meetup ───────────────────────────────────────────────────
# Get from: https://www.meetup.com/api/oauth/list/
MEETUP_API_KEY=your_meetup_api_key_here

# ─── CitySpark ────────────────────────────────────────────────
# Your CitySpark hub.cityspark.com login credentials
CITYSPARK_EMAIL=your@email.com
CITYSPARK_PASSWORD=your_password_here
# The exact submission URL for Washington Parent
CITYSPARK_SUBMIT_URL=https://hub.cityspark.com/event/submission/WashingtonParentMag

# ─── Search Config ────────────────────────────────────────────
# DMV area coordinates (Washington DC center)
SEARCH_LAT=38.9072
SEARCH_LNG=-77.0369
SEARCH_RADIUS_MILES=30
# How many days ahead to look for events
SEARCH_DAYS_AHEAD=60

# ─── Pipeline ─────────────────────────────────────────────────
# Run automatically on a cron schedule (e.g. "0 8 * * 1" = Mondays 8am)
CRON_SCHEDULE=0 8 * * 1
# Send email digest when new events are staged
NOTIFY_EMAIL=editor@washingtonparent.com
